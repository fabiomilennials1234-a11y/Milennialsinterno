# Segredos exclusivos de scripts/CLI — NUNCA entram no bundle do frontend.
# Copie para .env.scripts (gitignored) e preencha os valores reais.
#
# Pegue em: Dashboard > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Pegue em: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Senhas iniciais de bootstrap — usadas APENAS por:
#   - scripts/create-ceo-user.mjs / create-cto-user.mjs (cria/atualiza o user no Auth)
#   - scripts/test-create-user.mjs / diagnose-create-user.mjs (loga como CEO pra testar edge fn)
#
# Gere com: openssl rand -base64 20
# Depois de rotacionar no Supabase, atualize essas variáveis aqui e avise o dono
# do e-mail pra trocar no primeiro login. Nunca commite .env.scripts.
CEO_INITIAL_PASSWORD=
CTO_INITIAL_PASSWORD=
