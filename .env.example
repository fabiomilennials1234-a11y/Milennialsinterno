# Supabase - frontend e scripts
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key
VITE_SUPABASE_PROJECT_ID=seu_project_ref

# Necessário para scripts/create-ceo-user.mjs e setup-and-deploy-edge-functions.sh
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Necessário apenas para deploy das Edge Functions (setup-and-deploy-edge-functions.sh)
# Obtenha em: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=seu_access_token
