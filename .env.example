# Supabase - frontend (público, embutido no bundle via Vite).
# Apenas variáveis com prefixo VITE_ vão pro navegador.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key
VITE_SUPABASE_PROJECT_ID=seu_project_ref

# Segredos server-only (service role key, access token de deploy) ficam em .env.scripts.
# Veja .env.scripts.example. NUNCA coloque SUPABASE_SERVICE_ROLE_KEY neste arquivo.

# Feature flag — dual-read de permissões (user_page_grants)
# Deixe vazio/false para comportamento legado.
# Ligue (=true) para começar a gravar via grant_pages e logar divergências.
VITE_USE_PAGE_GRANTS=
